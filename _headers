##############################################################################
#  hafra.dz — HTTP Security Headers
#  These are applied at the CDN/hosting layer (Netlify / Cloudflare Pages).
#  They ENFORCE the same CSP declared in index.html as a defence-in-depth.
##############################################################################

/*
  # Prevent clickjacking — hafra.dz must never be embedded in an iframe
  X-Frame-Options: DENY

  # Force HTTPS for 1 year, include subdomains, submit to preload list
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Only send the origin as referrer (no full URL path)
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser features
  Permissions-Policy: geolocation=(self), camera=(self), microphone=(), payment=(), usb=(), interest-cohort=()

  # Content Security Policy (mirrors index.html meta tag — headers take precedence)
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://*.supabase.in https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.org; connect-src 'self' https://*.supabase.co https://*.supabase.in wss://*.supabase.co https://*.basemaps.cartocdn.com; worker-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'none';

  # Cross-Origin policies
  # NOTE: COEP require-corp is intentionally omitted — it would block CARTO tiles,
  # Google Fonts and CDN scripts which do not send CORP headers.
  Cross-Origin-Opener-Policy: same-origin

  # Cache control for HTML — always revalidate
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets — cache aggressively (1 year), they are content-addressed
/app.js
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=86400

/sw.js
  # Service worker must never be cached by the browser
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Admin route — additional protection
/admin.html
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, no-store, must-revalidate
